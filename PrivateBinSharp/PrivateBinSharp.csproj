<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ProduceReferenceAssembly>false</ProduceReferenceAssembly>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
	<JsonSerializerIsReflectionEnabledByDefault>false</JsonSerializerIsReflectionEnabledByDefault>
	  <DocumentationFile>PrivateBinSharp.xml</DocumentationFile>
    <Version>1.0.2</Version>
    <Authors>xXBuilderBXx</Authors>
	<Company>Fluxpoint Development</Company>
    <Description>C# PrivateBin API client for programs and automation!</Description>
    <PackageProjectUrl>https://github.com/xXBuilderBXx/PrivateBinSharp</PackageProjectUrl>
    <RepositoryUrl>https://github.com/xXBuilderBXx/PrivateBinSharp</RepositoryUrl>
    <PackageTags>privatebin</PackageTags>
  </PropertyGroup>

</Project>
